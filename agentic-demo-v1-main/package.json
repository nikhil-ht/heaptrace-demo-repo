{
  "name": "hypertension-fhir-dashboard",
  "private": true,
  "version": "0.1.0",
  "workspaces": ["app", "server"],
  "scripts": {
    "dev": "npm-run-all -p dev:server dev:app",
    "dev:server": "npm --workspace server run dev",
    "dev:app": "npm --workspace app run dev",
    "build": "npm --workspace app run build",
    "start": "npm --workspace server run start"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
